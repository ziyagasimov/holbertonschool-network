#!/usr/bin/env bash
# Set localhost to 127.0.0.2 and facebook.com to 8.8.8.8

# Change localhost from 127.0.0.1 to 127.0.0.2
sudo sed -i 's/^127\.0\.0\.1[[:space:]]*localhost$/127.0.0.2 localhost/' /etc/hosts

# Add facebook.com to resolve to 8.8.8.8
echo "8.8.8.8 facebook.com" | sudo tee -a /etc/hosts > /dev/null
